# IBK FSS 제재 브리핑 — 환경변수 예시
# 실제 값은 절대 이 파일에 쓰지 말 것 (GitHub Secrets로 주입)
# 로컬 테스트 시 Windows: HKCU\Environment 레지스트리에 저장
# 읽는 법: $env:ANTHROPIC_API_KEY = (Get-ItemProperty HKCU:\Environment).ANTHROPIC_API_KEY

ANTHROPIC_API_KEY=sk-ant-api03-...    # Anthropic API 키
TELEGRAM_BOT_TOKEN=...                # BotFather 발급 — FSS 전용 신규 봇 (결정 A, FSC와 분리)
TELEGRAM_CHAT_ID=...                  # 수신 chat_id (봇과 대화 후 getUpdates로 확인)
